{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MMYCodeSwitch-API",
  "version": "0.1.0",
  "identifier": "com.mmy.codeswitch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MMYCodeSwitch-API",
        "width": 900,
        "height": 620,
        "resizable": true,
        "center": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "id": "main"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "nsis": {
      "installMode": "currentUser",
      "languages": ["SimpChinese", "English"],
      "displayLanguageSelector": false,
      "installerIcon": "icons/icon.ico",
      "headerImage": "icons/header.bmp",
      "sidebarImage": "icons/installerSidebar.bmp",
      "uninstallerIcon": "icons/icon.ico",
      "license": "../LICENSE"
    },
    "macOS": {},
    "linux": {}
  }
}
